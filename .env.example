# Self-host baseline ports
CLUB_OS_WEB_PORT=3100
CLUB_OS_API_PORT=4100

# Web server -> API service URL inside docker network
CLUB_OS_API_BASE_URL=http://api:4100

# API runtime defaults
CLUB_OS_DEFAULT_ORG_ID=org-default
CLUB_OS_AUTO_SEED=true

# Optional for demo tenant bootstrap script
CLUB_OS_DEMO_ORG_ID=org-demo
CLUB_OS_DEMO_USER_ID=demo-admin
